<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head'); %>
</head>
<body>
  <header>
    <%- include('../partials/header'); %>
  </header>

  <main>

    <% if (user) { %>
    <p>Welkom <%= user.name %></p>
    <% } %>

    <form method="POST" action="/create-post" class="multi-step-form">

      <section class="form-step form-active">
        <h1 class="underline" >Maak je reis</h1> 
        <a href="discover"><img src="" alt="Terugknop naar discover"></a><!-- terugknop naar home -->

        <div class="voortgangsbalk">
            <div class="voortgangsbalk-active"></div>
            <div class="voortgangsbalk-inactive"></div>
        </div>
    
        <h2>Hier iets van tekst nog</h2>
        <h3>Algemene informatie</h3>

        <!-- cover foto -->

        <label>Titel</label>
        <input type="text" placeholder="Titel van de reis" />

        <label>Datum</label>
        <div>
          <input type="date" placeholder="Van" />
          <input type="date" placeholder="Tot" />
        </div>

        <label>Locatie</label>
        <input type="text" placeholder="Locatie" />

        <label>Hoeveel personen</label>
        <input type="number" placeholder="personen" />

        <button type="button" class="gradient-btn" data-next>Volgende</button>
      </section>

      <section class="form-step">
         <h1 class="underline" >Maak je reis</h1> <!-- dit mag dan geen h1 meer zijn????? -->
        <button type="button" data-prev>pijltje terug</button>

        <div class="voortgangsbalk">
            <div class="voortgangsbalk-active"></div>
            <div class="voortgangsbalk-active"></div>
        </div>
    
        <h2>Hier iets van tekst nog</h2>
        <h3>Details over de reis</h3>

        <label>Korte beschrijving</label>
        <input type="text" placeholder="Omschrijving van de reis" />

        <!-- route foto -->

        <label>Benodigdheden</label>
        <input type="text" placeholder="Wat heb je nodig voor deze reis?" />

        <!-- iput type welke???? -->
        <label>Leeftijd categorie</label>
        <input type="text">

        <label>Geslacht</label>
        <input type="text">

        <input class="gradient-btn" type="submit" value="Volgende">
      </section>


    </form>

    



  </main>
  <%- include('../partials/bottom-nav'); %>

  <script src="../script/form.js"></script>
</body>
</html>