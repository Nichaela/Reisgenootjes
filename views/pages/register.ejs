<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head'); %>

</head>

<body>
  <header>
    <%- include('../partials/header'); %>
    <link rel="stylesheet" href="css/form.css">
  </header>

  <main>
    <% if (error) { %>
      <p class="error">
        <%= error %>
      </p>
      <% } %>

        <!-- from van alle pagina's -->
        <form method="POST" action="/register" class="multi-step-form">
          <section class="form-step form-active"> <!-- eerste deel -->
            <h2 class="underline">Maak jou profiel</h2>

            <div class="voortgangsbalk">
              <div class="voortgangsbalk-active"></div>
              <div class="voortgangsbalk-inactive"></div>
              <div class="voortgangsbalk-inactive"></div>
              <div class="voortgangsbalk-inactive"></div>
            </div>

            <p>Hier iets van tekst nog</p>
            <p>Account aanmaken</p>


            <label for="name">Voornaam</label>
            <input type="text" id="name" name="name" required>

            <label for="lastName">Achternaam:</label>
            <input type="text" id="lastName" name="lastName" required>

            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>

            <label for="password">Wachtwoord</label>
            <input type="password" id="wachtwoord" name="password" required>

            <label for="confirmPassword">Herhaal wachtwoord</label>
            <input type="password" id="confirmPassword" name="confirmPassword" required>

            <button type="button" class="gradient-btn" data-next>volgende</button>

          </section>
          <section class="form-step"> <!--tweede deel-->
            <h2 class="underline">Maak jou profiel</h2>

            <div class="voortgangsbalk">
              <div class="voortgangsbalk-active"></div>
              <div class="voortgangsbalk-active"></div>
              <div class="voortgangsbalk-inactive"></div>
              <div class="voortgangsbalk-inactive"></div>
            </div>

            <p>Hier iets van tekst nog</p>
            <p>Account aanmaken</p>

            <input type="file" name="avatar" accept="image/*">

            <label for="username">Naam</label>
            <input type="text" id="username" name="username" required>

            <label for="birthday">Verjaardag</label>
            <input type="date" name="birthday" id="birthday" required>

            <label for="telefoon">Telefoon</label>
            <input type="tel" id="telefoon" name="telefoon">

            <label for="gender">Gender</label>
            <select name="gender" id="gender" required>
              <option value="">Kies je gender</option>
              <option value="Man">Man</option>
              <option value="Vrouw">Vrouw</option>
              <option value="Anders">Anders</option>
            </select>

            <button type="button" class="gradient-btn" data-next>Volgende</button>
          </section>

            <section class="form-step"> <!--derde deel-->
              <h2 class="underline">Maak jou profiel</h2>
  
              <div class="voortgangsbalk">
                <div class="voortgangsbalk-active"></div>
                <div class="voortgangsbalk-active"></div>
                <div class="voortgangsbalk-active"></div>
                <div class="voortgangsbalk-inactive"></div>
              </div>
  
              <p>Welke manieren van reizen spreken jou aan?</p>
              <p>Selecteer 5 onderwerpen</p>

              <button type="button" class="gradient-btn" data-next>Volgende</button>
            </section>

            <section class="form-step"> <!--vierde deel-->
              <h2 class="underline">Jouw profiel</h2>
  
              <div class="voortgangsbalk">
                <div class="voortgangsbalk-active"></div>
                <div class="voortgangsbalk-active"></div>
                <div class="voortgangsbalk-active"></div>
                <div class="voortgangsbalk-active"></div>
              </div>
              
              <input type="file" name="avatar" accept="image/*">
              <input type="file" name="avatar" accept="image/*">
              <input type="file" name="avatar" accept="image/*">
              <input type="file" name="avatar" accept="image/*">

              <section>
                <h3>Naam...</h3>
                  <p> <!--icon--> Geslacht</p>
                <div>
                  <img src="" alt="">
                  <p> <!--icon--> Leeftijd</p>
                </div>
              </section>

              <p>Status •</p> <input type="text">

              <h2>Bio</h2>
              <input type="text">

              <h2>Interesses</h2>

              <input class="gradient-btn" type="submit" value="Profiel aanmaken">
            </section>
        </form>

  </main>
  <footer>
    <%- include('../partials/bottom-nav'); %>
</footer>

    <script src="../script/form.js"></script>

</body>

</html>