<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head'); %>
  <link rel="stylesheet" href="css/matchen.css">
  <link rel="stylesheet" href="css/filter.css">
  <link rel="stylesheet" href="style.css">
   <script defer src="javascript/filter.js"></script>
</head>
<body>
  <header>
    <%- include('../partials/header'); %>
  </header>

  <main>
   <% if (user) { %>
  <p>Welkom <%= user.name %></p>
  <% } %> 

  <h1 class="underline" >Matchen</h1>
  <%- include('../partials/filtermenu'); %>
 
  
  

   <section>
  <img src="img/accounts/MarkvanFlied.jpg" alt="Account foto">
  <div class="profile-info">
   <h2><%= matchUser.name %> • <%= age %></h2>
    <ul>
      <li><img src="img/matcheniconen/gendermale.svg"><%= matchUser.gender %></li>
      <li><img src="img/matcheniconen/MapPin.svg">55 km van jou vandaan</li>
      <li><img src="img/matcheniconen/waarreizen.svg">Reizen door Oosterijk</li>
      <li><img src="img/matcheniconen/Smiley.svg"> Gezamenlijke interesse</li>
    </ul>
  </div>
</section>

<section>
    <p>State • Opzoek naar reisgenootje</p>
    <h2>Bio</h2>
    <p><%= matchUser.bio %></p>
</section>

<section>
  <h2>Interesse</h2>
   <ul class="hobbies">
    <% matchUser.interests.split(',').forEach(interesse => { %>
      <li class="hobby"><%= interesse %></li>
    <% }) %>
  </ul>
</section>

<section>
  <h2>Geplande trip</h2>
   <a href="/post/<%= post._id %>">
  <%- include('../partials/reisoproep', { post: post }) %>
</a>
</section>

<section>
    <h2>Op zoek naar:</h2>
  <p><%= matchUser.opzoek %></p>
</section>

<section>
    <h2>Gallerij</h2>
    <img src="img/accounts/markvoorkant.jpg" alt="mark van de voorkant">
    <img src="img/accounts/markwandelen.jpg" alt="mark die aan het wandelen is">
    <img src="img/accounts/tentje.jpg" alt="een tentje in de bergen met uitzicht">
</section>

<section>
<button><img src="img/matcheniconen/kruis.svg" alt="Dislike"></button>
<button><img src="img/matcheniconen/Heart.svg" alt="Like"></button>
</section>


  </main>
  <%- include('../partials/bottom-nav'); %>
</body>
</html>