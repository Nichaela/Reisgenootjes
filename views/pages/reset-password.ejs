<!DOCTYPE html>
<html lang="nl">
<head>
    <%- include('../partials/head'); %>
    <link rel="stylesheet" href="/css/form.css">
</head>
<body>
  <h1>Reset je wachtwoord</h1>

  <% if (typeof error !== 'undefined' && error) { %>
    <p><%= error %></p>
  <% } %>

  <% if (typeof success !== 'undefined' && success) { %>
    <p> <%= success %></p>
  <% } %>

  <form action="/reset-password" method="POST" class="inlogform">
    <!-- verborgen input om token mee te sturen -->
    <input type="hidden" name="token" value="<%= token %>">

    <label for="password">Wachtwoord</label>
    <input type="password" id="password" name="password" required minlength="8">

    <label for="confirmPassword">Herhaal wachtwoord</label>
    <input type="password" id="confirmPassword" name="confirmPassword" required>

    <input type="submit" class="gradient-btn" value="wachtwoord resetten">
  </form>

  <p>
    <a href="/login">Terug naar login</a>
  </p>
</body>
</html>