<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <link rel="stylesheet" href="css/matchen.css">
        <title>Profielpagina <%= user.name %></title>
</head> 

<body>
    <header>
        <%- include('../partials/header'); %>
    </header>
    <main>
        <% if (user) { %>
            <h1 class="underline">Welkom <%= user.name %></h1>
            <!-- Foto's -->
            <section>
                <!-- birthday naar age uitrekenen? -->
                <h2><%= user.name %> • <%= user.birthday %></h2>
                <div class="profile-info">
                    <ul>
                        <li><%= user.gender %></li>

                        <!-- locatie ophalen hoe? -->
                        <li>Nederland</li>
                    </ul>
                </div>
            </section>

            <section>
            <!-- dit moet nog uit de db -->
                <p>State • Opzoek naar reisgenootje</p>
                <h2>Bio</h2>
                <p><%= user.bio %></p>
            </section>

            <!-- dit moet nog uit de db -->
            <section>
                <ul class="hobbies">
                    <li class="hobby">Sport</li>
                    <li class="hobby">Reizen</li>
                    <li class="hobby">Muziek</li>
                    <li class="hobby">Hiken</li>
                </ul>
            </section>


            <h2>Planning</h2>
            <ul class="discover">
                <% posts.forEach(post => { %>
                <li>
                    <a href="/post/<%= post._id %>">
                    <!-- zonder de {post: post} krijg ik not defined -->
                    <%- include('../partials/reisoproep', { post: post }) %>
                    </a>
                </li><% }) %>
                </ul>
            </section>
        <% } %>
    </main>

    <footer>
        <%- include('../partials/bottom-nav'); %>
    </footer>
</body>

</html>