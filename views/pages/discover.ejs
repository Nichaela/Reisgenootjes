<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head'); %>
  <link rel="stylesheet" href="/css/matchen.css">
</head>
<body>
  <main>
    <h1 class="underline" >Ontdek</h1>
    <!-- filterknop -->
    <!-- onderweg -->
    <!-- opzoek -->

    <%- include('../partials/zoekbalk') %>

    <ul class="reizen">
      <% posts.forEach(post => { %>
      <li>
        <a href="/post/<%= post._id %>">
          <!-- zonder de {post: post} krijg ik not defined -->
          <%- include('../partials/reisoproep', { post: post }) %>
        </a>
      </li><% }) %>
    </ul>

    <div id="noResults" style="display:none;">
      <p>Geen resultaten gevonden</p>
      <img src="/img/404.svg" alt="">
    </div>

  </main>

  <footer>
    <%- include('../partials/bottom-nav'); %>
  </footer>

  <script src="../script/form.js"></script>
</body>
</html>